{
  "name": "通用本科毕业设计格式",
  "margins": {
    "top_cm": 2.5,
    "bottom_cm": 2.5,
    "left_cm": 2.8,
    "right_cm": 2.5
  },
  "body": {
    "font_east_asia": "宋体",
    "font_ascii": "Times New Roman",
    "font_size_pt": 12.0,
    "line_spacing": 1.5,
    "first_line_indent_chars": 2.0,
    "alignment": "both"
  },
  "caption": {
    "font_east_asia": "宋体",
    "font_ascii": "Times New Roman",
    "font_size_pt": 10.5,
    "alignment": "center",
    "figure_prefix": "图",
    "table_prefix": "表"
  },
  "reference": {
    "title": "参考文献",
    "citation_pattern": "\\[(\\d+)\\]",
    "ordered_numeric": true
  },
  "headings": [
    {
      "level": 1,
      "font_east_asia": "黑体",
      "font_ascii": "Times New Roman",
      "font_size_pt": 15.0,
      "bold": true,
      "alignment": "center",
      "page_break_before": true
    },
    {
      "level": 2,
      "font_east_asia": "黑体",
      "font_ascii": "Times New Roman",
      "font_size_pt": 14.0,
      "bold": true,
      "alignment": "left",
      "page_break_before": false
    },
    {
      "level": 3,
      "font_east_asia": "宋体",
      "font_ascii": "Times New Roman",
      "font_size_pt": 12.0,
      "bold": true,
      "alignment": "left",
      "page_break_before": false
    }
  ]
}